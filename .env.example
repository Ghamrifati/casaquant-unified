# CasaQuant Unified — Configuration d'environnement
# Copier ce fichier en .env et adapter les valeurs

# ── Base de données ──────────────────────────────────────────────
DATABASE_URL=postgresql://cq:cq_secret@db:5432/casaquant
# Mode offline (développement sans Docker) :
# DATABASE_URL=sqlite:///data/casaquant_unified.db

# ── Cache / Queue ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Environnement ──────────────────────────────────────────────────
CASAQUANT_ENV=development
# CASAQUANT_ENV=production

# ── Sécurité ─────────────────────────────────────────────────────
API_KEY=dev_key_change_me_in_production

# ── IA / Ollama ──────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_BACKOFF=2

# ── Scraping BVC ─────────────────────────────────────────────────
CASABOURSE_API_URL=https://api.casabourse.ma
WAFABOURSE_URL=https://www.wafabourse.com
SCRAPER_TIMEOUT=40
SCRAPER_MAX_RETRIES=3

# ── Notifications ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Marché BVC ───────────────────────────────────────────────────
BVC_TAX_RATE=0.001
BVC_BROKERAGE_RATE=0.006
BVC_VAT_RATE=0.10
BVC_MIN_BROKERAGE=10.0
